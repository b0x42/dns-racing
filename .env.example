# DNS Racing configuration
# These can also be set via CLI flags (flags take precedence).
# Run `dns-racing --help` for all options.

CUSTOM_DNS=192.168.0.5          # --custom-dns
CUSTOM_DNS_LABEL=AdGuard        # --custom-dns-label
CLOUDFLARE=1.1.1.1              # --public-dns
EXTRA_DNS=                      # --extra-dns  (e.g. 8.8.8.8:Google,9.9.9.9:Quad9)
RPS=25                          # --rps
STATS_EVERY=5000                # --stats-every
TIMEOUT=5000                    # --timeout
WINDOW=500                      # --window
WARMUP_ROUNDS=2                 # --warmup-rounds
CACHE_HIT_MS=1.0                # --cache-hit-ms
